# ─────────────────────────────────────────────────────────────────────────────
# EcoCoin V — Polygon Configuration
# Copy this file to .env and fill in your values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Deployer private key (without 0x prefix)
PRIVATE_KEY=your_wallet_private_key_here_without_0x

# ─── Polygon RPC URLs ────────────────────────────────────────────────────────
# Amoy Testnet — free public RPC (or use Alchemy/QuickNode for reliability)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Mainnet — use Alchemy or QuickNode for production
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── API Keys ────────────────────────────────────────────────────────────────
# Get free key at https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Optional — for gas cost reporting in USD
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
REPORT_GAS=false

# ─── Distribution Wallet Addresses ───────────────────────────────────────────
# These wallets receive ECC tokens at deployment (from the 100M total supply)
CARBON_REWARDS_WALLET=0xYourCarbonRewardsWallet
COMMUNITY_WALLET=0xYourCommunityWallet
DEVELOPMENT_WALLET=0xYourDevelopmentWallet
MARKETING_WALLET=0xYourMarketingWallet
LIQUIDITY_WALLET=0xYourLiquidityWallet
TEAM_WALLET=0xYourTeamWallet
ADVISORS_WALLET=0xYourAdvisorsWallet
RESERVE_WALLET=0xYourReserveWallet

# ─── Airdrop Config ──────────────────────────────────────────────────────────
# Address of deployed EcoCoinV7Secured on Polygon (set after first deployment)
ECC_TOKEN_ADDRESS=0xDeployedEccTokenAddressHere

# ─── Backend ─────────────────────────────────────────────────────────────────
JWT_SECRET=generate_with__node_-e_"require('crypto').randomBytes(64).toString('hex')"
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
ADMIN_ADDRESSES=0xYourAdminWalletAddress
TREASURY_WALLET=0xYourTreasuryWalletAddress
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
