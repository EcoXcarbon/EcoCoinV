# ═══════════════════════════════════════════════════════════════
# ECOCOIN SECURED BACKEND CONFIGURATION
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# CRITICAL - JWT Secret Key
# ─────────────────────────────────────────────────────────────
# REQUIRED for authentication
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_min_64_characters_change_this_in_production

# ─────────────────────────────────────────────────────────────
# CRITICAL - Admin Wallet Addresses
# ─────────────────────────────────────────────────────────────
# Comma-separated list of Ethereum addresses with admin privileges
# Add YOUR wallet address here!
ADMIN_ADDRESSES=0x2F1a7d23C0bE593B39352F9fD3BAED37DC9Ff686

# ─────────────────────────────────────────────────────────────
# CRITICAL - Frontend URL (CORS)
# ─────────────────────────────────────────────────────────────
# Your frontend domain for CORS restrictions
# Production: https://your-domain.netlify.app
# Development: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# OPTIONAL - Server Settings
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════
# PRODUCTION EXAMPLE
# ═══════════════════════════════════════════════════════════════
# JWT_SECRET=a1b2c3d4e5f6...your_64_char_secret
# ADMIN_ADDRESSES=0xYourAddress,0xAnotherAdminAddress
# FRONTEND_URL=https://ecocoin.yourdomain.com
# PORT=3000
# NODE_ENV=production
