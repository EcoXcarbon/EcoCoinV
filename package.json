{
  "name": "ecocoin-polygon",
  "version": "5.0.0",
  "description": "EcoCoin (ECC) — Carbon Credit Platform on Polygon",
  "scripts": {
    "compile": "node --max-old-space-size=4096 node_modules/.bin/hardhat compile",
    "test": "node --max-old-space-size=4096 node_modules/.bin/hardhat test",
    "coverage": "hardhat coverage",
    "deploy:amoy": "node --max-old-space-size=4096 node_modules/.bin/hardhat run scripts/deploy-polygon-amoy.js --network polygonAmoy",
    "deploy:mainnet": "node --max-old-space-size=2048 node_modules/hardhat/internal/cli/cli.js run scripts/deploy-polygon-mainnet.js --network polygonMainnet --no-compile",
    "airdrop:amoy": "hardhat run scripts/airdrop.js --network polygonAmoy",
    "airdrop:mainnet": "hardhat run scripts/airdrop.js --network polygonMainnet",
    "verify:amoy": "hardhat verify --network polygonAmoy",
    "verify:mainnet": "hardhat verify --network polygonMainnet",
    "node": "hardhat node",
    "deploy:local": "node --max-old-space-size=4096 node_modules/.bin/hardhat run scripts/deploy-polygon-amoy.js --network hardhat",
    "deploy:local:fast": "node --max-old-space-size=2048 node_modules/hardhat/internal/cli/cli.js run scripts/deploy-polygon-amoy.js --network hardhat --no-compile",
    "deploy:bsctest": "node --max-old-space-size=2048 node_modules/hardhat/internal/cli/cli.js run scripts/deploy-polygon-amoy.js --network bscTestnet --no-compile"
  },
  "keywords": [
    "ecocoin",
    "polygon",
    "carbon-credits",
    "web3",
    "sustainability"
  ],
  "author": "Yasir - IMSciences",
  "license": "MIT",
  "dependencies": {
    "@chainlink/contracts": "^0.8.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/hardhat-upgrades": "^2.5.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^2.3.0",
    "nodemon": "^3.0.2",
    "solidity-coverage": "^0.8.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
